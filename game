import pygame

RESOLUTION = (800, 600)

def main():
    pygame.init()

    # Create window
    window = pygame.display.set_mode(RESOLUTION)
    pygame.display.set_caption("Collision Game")
    speed = 20

    # Define rect outside the loop to persist position
    rect = pygame.Rect(50, 50, 50, 50)

    # Font and text setup
    font = pygame.font.SysFont("Comic Sans MS", 40)
    score = 0
    text_surface = font.render(f"Score: {score}", True, (255, 0, 0))

    # Clock for tracking time
    clock = pygame.time.Clock()
    last_score_time = pygame.time.get_ticks()

    running = True
    while running:
        # Clear screen each frame
        window.fill((255, 255, 255))

        # Draw rectangle
        pygame.draw.rect(window, (255, 0, 0), rect)

        # Update score every second
        current_time = pygame.time.get_ticks()
        if current_time - last_score_time >= 1000:
            score += 1
            text_surface = font.render(f"Score: {score}", True, (255, 0, 0))
            last_score_time = current_time

        text_rect = text_surface.get_rect()

        # Calculate bottom right position
        text_x = RESOLUTION[0] - text_rect.width - 10  
        text_y = RESOLUTION[1] - text_rect.height - 10  

        # Draw text at bottom right
        window.blit(text_surface, (text_x, text_y))

        for event in pygame.event.get():
            if event.type == pygame.QUIT:  # Handle window close
                running = False

            elif event.type == pygame.KEYDOWN:
                if event.key == pygame.K_LEFT:
                    rect.x -= speed
                elif event.key == pygame.K_RIGHT:
                    rect.x += speed
                elif event.key == pygame.K_UP:
                    rect.y -= speed
                elif event.key == pygame.K_DOWN:
                    rect.y += speed

        # Update display each frame
        pygame.display.update()
        clock.tick(60)  # 60 FPS

    pygame.quit()

main()
